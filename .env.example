# ============================================================
# SolveBeat Backend — Environment Example
# Copy to .env and fill in real values:
#   cp .env.example .env
# ============================================================

# -------------------- App --------------------
PORT=5000
NODE_ENV=dev

# -------------------- MongoDB --------------------
USER_DB_URL=mongodb://localhost:27017/solvebeat
USERS_DB_POOLSIZE=10

# -------------------- Redis (required for BullMQ scan queues) --------------------
REDIS_HOST=localhost
REDIS_HOST_NAME=localhost
REDIS_PORT=6379
# Redis 5.x: password only (no username). Leave empty if Redis has no requirepass.
REDIS_PASSWORD=
# Redis 6+ ACL only — do NOT set on Redis 5.x
REDIS_USERNAME=
REDIS_DB=0
REDIS_MODE=single
# Optional full URL if your setup uses it elsewhere
REDIS_CONNECTION_STRING=redis://localhost:6379

# -------------------- JWT / Auth --------------------
JWT_SECRET=change_me_admin_secret
JWT_SECRET_USER=change_me_user_secret
JWT_VALIDITY=30d
REFRESH_TOKEN_SECRET=change_me_refresh_secret
REFRESH_TOKEN_VALIDITY=30d

# -------------------- Google OAuth --------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -------------------- URLs --------------------
FRONTEND_HOST_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# -------------------- Guest scans --------------------
GUEST_FREE_SCANS=1
GUEST_SCAN_TTL=2592000
GUEST_TOKEN_VALIDITY=24h
GUEST_IDENTITY_TTL_DAYS=365

# -------------------- Scan runtime (BullMQ / MongoDB) --------------------
SCAN_WORKER_CONCURRENCY=5
SCAN_PARENT_CONCURRENCY=2
SCAN_MODULE_TIMEOUT_MS=30000
# Per-module retry: 3 attempts total, exponential backoff between attempts
SCAN_MODULE_MAX_ATTEMPTS=3
SCAN_MODULE_RETRY_BACKOFF_MS=2000
SCAN_HTTP_TIMEOUT_MS=15000
SCAN_HTTP_MAX_REDIRECTS=5
SCAN_HTTP_USER_AGENT=SolveBeatHeaderScanner/1.0

# -------------------- Debug logging --------------------
# When true, logs extra per-attempt/per-module debug detail (see docs/SCANNING.md)
DEBUG_LOG=false

# -------------------- SSL scanner --------------------
SCAN_SSL_TIMEOUT_MS=15000
SCAN_SSL_EXPIRY_WARN_DAYS=30

# -------------------- DNS scanner --------------------
SCAN_DNS_TIMEOUT_MS=10000

# -------------------- Technology scanner --------------------
SCAN_TECH_TIMEOUT_MS=15000
SCAN_TECH_MAX_HTML_BYTES=2097152
SCAN_TECH_USER_AGENT=SolveBeatTechScanner/1.0

# -------------------- JavaScript scanner --------------------
SCAN_JS_TIMEOUT_MS=15000
SCAN_JS_MAX_SCRIPTS=20
SCAN_JS_MAX_FILE_BYTES=2097152
SCAN_JS_MAX_HTML_BYTES=2097152
SCAN_JS_LARGE_BUNDLE_BYTES=512000
SCAN_JS_CONCURRENCY=5
SCAN_JS_USER_AGENT=SolveBeatJsScanner/1.0

# -------------------- Secret scanner --------------------
SCAN_SECRET_TIMEOUT_MS=15000
SCAN_SECRET_MAX_RESOURCES=20
SCAN_SECRET_MAX_FILE_BYTES=2097152
SCAN_SECRET_CONCURRENCY=5
SCAN_SECRET_USER_AGENT=SolveBeatSecretScanner/1.0

# -------------------- SEO scanner --------------------
SCAN_SEO_TIMEOUT_MS=15000
SCAN_SEO_MAX_HTML_BYTES=2097152
SCAN_SEO_LINK_CHECK_LIMIT=15
SCAN_SEO_IMAGE_CHECK_LIMIT=10
SCAN_SEO_CONCURRENCY=5
SCAN_SEO_USER_AGENT=SolveBeatSeoScanner/1.0

# -------------------- Performance scanner --------------------
SCAN_PERF_TIMEOUT_MS=15000
SCAN_PERF_MAX_HTML_BYTES=2097152
SCAN_PERF_MAX_RESOURCE_BYTES=2097152
SCAN_PERF_MAX_RESOURCES=100
SCAN_PERF_CONCURRENCY=5
SCAN_PERF_USER_AGENT=SolveBeatPerfScanner/1.0

# -------------------- Infrastructure scanner --------------------
# Runs in phase 2 — reads header/ssl/dns/tech/performance results directly from MongoDB
SCAN_INFRA_TIMEOUT_MS=10000
SCAN_INFRA_USER_AGENT=SolveBeatInfraScanner/1.0

# -------------------- Threat scanner --------------------
# Runs in phase 2 — reads sibling results (incl. infrastructure) directly from MongoDB

# -------------------- Compliance scanner --------------------
# Runs in phase 2 — reads all sibling results (incl. threat) directly from MongoDB

# Active scanning (future) — keep false for passive-only production
ENABLE_ACTIVE_SCANNER=false

# -------------------- Reports / S3 (optional) --------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_REPORT_BUCKET=
S3_REPORT_PATH=reports/
LOCAL_REPORT_PATH=public/reports

# -------------------- Misc --------------------
THRESHOLD_RATE_LIMIT=30
CRON_AUTH_TOKEN=
SENTRY_DSN=

# -------------------- OTP / Email --------------------
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_MAX_SEND_PER_WINDOW=5
OTP_SEND_WINDOW_MINUTES=15
OTP_MAX_VERIFY_ATTEMPTS=5
ENABLE_STATIC_OTP=true
STATIC_OTP=123456

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
